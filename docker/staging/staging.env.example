# Safe validation template only. Do not deploy these placeholder values.
COMPOSE_PROJECT_NAME=school_newsroom_staging
STAGING_HOSTNAME=staging.example.invalid
ACME_EMAIL=operator@example.invalid

DJANGO_SECRET_KEY=replace-with-a-strong-random-secret
DJANGO_ALLOWED_HOSTS=staging.example.invalid
DJANGO_CSRF_TRUSTED_ORIGINS=https://staging.example.invalid
DJANGO_WAGTAILADMIN_BASE_URL=https://staging.example.invalid
DJANGO_LOG_LEVEL=INFO
DJANGO_SECURE_SSL_REDIRECT=true
DJANGO_SECURE_HSTS_SECONDS=3600
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=false
DJANGO_SECURE_HSTS_PRELOAD=false
SEO_DEFAULT_NOINDEX=true

POSTGRES_DB=school_newsroom
POSTGRES_USER=school_newsroom_staging
POSTGRES_PASSWORD=replace-with-a-strong-random-database-password
DATABASE_URL=postgresql://school_newsroom_staging:replace-with-a-strong-random-database-password@db:5432/school_newsroom

GUNICORN_WORKERS=2
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=60
GUNICORN_LOG_LEVEL=info
